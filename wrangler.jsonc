{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "singularidade-online",
  "main": "cloudflare/worker.ts",
  "compatibility_date": "2026-04-08",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none",
    "not_found_handling": "single-page-application"
  }
}
